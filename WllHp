-- ══════════════════════════════════════
-- WALLHOP LOGIC
-- ══════════════════════════════════════
local function detectWall()
	if proximityOffset<=0 then return nil end
	local rp=RaycastParams.new()
	rp.FilterDescendantsInstances={character}; rp.FilterType=Enum.RaycastFilterType.Exclude
	local dirs={Vector3.new(1,0,0),Vector3.new(-1,0,0),Vector3.new(0,0,1),Vector3.new(0,0,-1)}
	for _,d in ipairs(dirs) do
		local res=workspace:Raycast(rootPart.Position,d*(proximityOffset+0.55),rp)
		if res then return res.Normal end
	end
end

local function smoothWallhop(wallNormal)
	if isWallhopping then return end
	isWallhopping=true

	local startCF=rootPart.CFrame
	local startYaw=math.atan2(startCF.LookVector.X,startCF.LookVector.Z)
	local wallAngle=math.atan2(wallNormal.X,wallNormal.Z)
	-- target is 45 degrees offset from wall normal
	local targetYaw=wallAngle+math.pi/4
	local diff=targetYaw-startYaw
	while diff>math.pi do diff-=2*math.pi end
	while diff<-math.pi do diff+=2*math.pi end

	-- natural hop — gentle push upward, not a rocket
	local vel=rootPart.AssemblyLinearVelocity
	rootPart.AssemblyLinearVelocity=Vector3.new(vel.X, 22, vel.Z)

	-- smooth rotation 0 → 45 deg over ~0.6s with natural easing
	local duration=0.60
	local elapsed=0
	local conn
	conn=RunService.Heartbeat:Connect(function(dt)
		elapsed=math.min(elapsed+dt, duration)
		local t=elapsed/duration
		-- ease-out quad: fast start, gentle finish — feels natural
		local ease=1-(1-t)*(1-t)
		local yaw=startYaw+diff*ease
		rootPart.CFrame=CFrame.new(rootPart.Position)*CFrame.Angles(0,yaw,0)
		if elapsed>=duration then
			conn:Disconnect(); isWallhopping=false
		end
	end)
end

local function onJump()
	if not wallhopEnabled or proximityOffset<=0 then return end
	local now=tick()
	if now-lastJumpTime<0.85 then
		jumpCount+=1
		if jumpCount>=2 then
			jumpCount=0
			local wn=detectWall()
			if wn then smoothWallhop(wn) end
		end
	else
		jumpCount=1
	end
	lastJumpTime=now
end

humanoid.Jumping:Connect(function(j) if j then onJump() end end)

player.CharacterAdded:Connect(function(nc)
	character=nc
	humanoid=nc:WaitForChild("Humanoid")
	rootPart=nc:WaitForChild("HumanoidRootPart")
	isWallhopping=false; jumpCount=0
	humanoid.Jumping:Connect(function(j) if j then onJump() end end)
end)

