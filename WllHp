local function applyTheme()
	local col=C()
	mfStr.Color=col.stroke
	bgGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,col.bg1),ColorSequenceKeypoint.new(1,col.bg2)})
	mf.BackgroundColor3=col.bg1
	shd.BackgroundColor3=col.shd
	tbGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,col.bar1),ColorSequenceKeypoint.new(1,col.bar2)})
	tb.BackgroundColor3=col.bar1; tbFix.BackgroundColor3=col.bar2
	proxLbl.TextColor3=col.proxTxt; infoLbl.TextColor3=col.infoTxt
	slTrack.BackgroundColor3=col.track
	slFill.BackgroundColor3=col.fill1
	slFillG.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,col.fill1),ColorSequenceKeypoint.new(1,col.fill2)})
	slKnob.BackgroundColor3=col.knob; slKnob.TextColor3=col.knobStr; slKStr.Color=col.knobStr
	slKShd.BackgroundColor3=col.btnShd
	rstBtn.BackgroundColor3=col.btn1
	rstGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,col.btn1),ColorSequenceKeypoint.new(1,col.btn2)})
	rstShd.BackgroundColor3=col.btnShd

	-- moon cut matches bar
	mCut.BackgroundColor3=col.bar2
	sH.Visible=not isDarkMode; mH.Visible=isDarkMode

	-- buttons (only update if disabled)
	if not wallhopEnabled then
		whGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,col.btn1),ColorSequenceKeypoint.new(1,col.btn2)})
		whShd.BackgroundColor3=col.btnShd
	end
	if not infiniteJumpEnabled then
		ijGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,col.btn1),ColorSequenceKeypoint.new(1,col.btn2)})
		ijShd.BackgroundColor3=col.btnShd
	end
end

