local function makeBtn(parent, py, h, label)
	local wrap=Instance.new("Frame",parent)
	wrap.Size=UDim2.new(1,0,0,h); wrap.Position=UDim2.new(0,0,0,py)
	wrap.BackgroundTransparency=1

	local shd2=Instance.new("Frame",wrap)
