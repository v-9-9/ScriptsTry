-- ══════════════════════════════════════════
--              FLICK (Wall-Jump)
-- ══════════════════════════════════════════
local flickConnection
local flickTweening = false

local function doFlickTween(hrp)
	if flickTweening then return end
	flickTweening = true
	local startCF = hrp.CFrame
	local angles = {0, 15, 30, 45, 30, 15, 0}
	local idx = 1
	local function step()
		if idx > #angles or not State.FlickOn then
			flickTweening = false
			return
		end
		local angle = math.rad(angles[idx])
		local targetCF = CFrame.new(hrp.Position) * CFrame.Angles(0, angle, 0)
		local tw = TweenService:Create(hrp, TweenInfo.new(0.06, Enum.EasingStyle.Linear), {CFrame = targetCF})
		tw:Play()
		tw.Completed:Connect(function()
			idx = idx + 1
			step()
		end)
	end
	step()
end

local function setupFlick()
	if flickConnection then flickConnection:Disconnect() end
	if not State.FlickOn then return end

	flickConnection = UserInputService.JumpRequest:Connect(function()
		local hrp = getHRP()
		local hum = getHumanoid()
		if not hrp or not hum then return end
		local near, _ = isNearWall()
		if near then
			hum.Jump = true
			doFlickTween(hrp)
		end
	end)
end

-- ══════════════════════════════════════════
--              JUKE / DODGE
-- ══════════════════════════════════════════
local function doJuke(targetChar)
	if State.JukeActive then return end
	State.JukeActive = true
	local hrp = getHRP()
	local hum = getHumanoid()
	if not hrp or not hum then State.JukeActive = false return end

	-- Jump over target head
	local targetRoot = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
	if targetRoot then
		local above = targetRoot.Position + Vector3.new(0, 8, 0)
		-- Tween position toward above target
		hum.Jump = true
		local bodyVel = Instance.new("BodyVelocity")
		bodyVel.Velocity = (above - hrp.Position).Unit * 40
		bodyVel.MaxForce = Vector3.new(1e5, 1e5, 1e5)
		bodyVel.Parent = hrp
		task.delay(0.3, function() bodyVel:Destroy() end)
	end

	-- Second jump: random escape direction
	task.delay(0.35, function()
		local hrp2 = getHRP()
		local hum2 = getHumanoid()
		if hrp2 and hum2 then
			hum2.Jump = true
			local randAngle = math.random(0, 360)
			local dir = Vector3.new(math.cos(math.rad(randAngle)), 0, math.sin(math.rad(randAngle)))
			local bv2 = Instance.new("BodyVelocity")
			bv2.Velocity = dir * 35 + Vector3.new(0, 20, 0)
			bv2.MaxForce = Vector3.new(1e5, 1e5, 1e5)
			bv2.Parent = hrp2
			task.delay(0.3, function() bv2:Destroy() end)
		end
		task.delay(0.5, function() State.JukeActive = false end)
	end)
end

-- ══════════════════════════════════════════
--              AUTO (Pathfinding Chase)
-- ══════════════════════════════════════════
local autoThread
local pathConnection
local fakeoutCooldown = false

local function fakeMoveRight(hrp, hum, duration)
	-- Fake right then dash left toward target
	if fakeoutCooldown then return end
	fakeoutCooldown = true
	local rightDir = hrp.CFrame.RightVector
	local bv = Instance.new("BodyVelocity")
	bv.Velocity = rightDir * 18
	bv.MaxForce = Vector3.new(1e5, 0, 1e5)
	bv.Parent = hrp
	task.delay(0.18, function()
		bv:Destroy()
		-- dash toward target
		local t = State.Target
		if t and t.Character then
			local tRoot = t.Character:FindFirstChild("HumanoidRootPart")
			local myHRP = getHRP()
			if tRoot and myHRP then
				local toTarget = (tRoot.Position - myHRP.Position).Unit
				local bv2 = Instance.new("BodyVelocity")
				bv2.Velocity = toTarget * 40
				bv2.MaxForce = Vector3.new(1e5, 0, 1e5)
				bv2.Parent = myHRP
				task.delay(0.25, function() bv2:Destroy() end)
			end
		end
		task.delay(1, function() fakeoutCooldown = false end)
	end)
end

local function runAutoChase()
	while State.AutoOn and State.Mode == "chasing" do
		if not hasBombTool() then task.wait(0.5) continue end

		local target = findNearestTarget()
		State.Target = target

		if not target then
			GUI.UsernameLabel.Text = "(username)"
			task.wait(0.5)
			continue
		end

		GUI.UsernameLabel.Text = target.Name

		local hrp = getHRP()
		local hum = getHumanoid()
		local tChar = target.Character
		if not hrp or not hum or not tChar then task.wait(0.3) continue end
		local tRoot = tChar:FindFirstChild("HumanoidRootPart")
		if not tRoot then task.wait(0.3) continue end

		-- Pathfinding
		local path = PathfindingService:CreatePath({
			AgentHeight = 5,
			AgentRadius = 2,
			AgentCanJump = true,
			WaypointSpacing = 4,
		})

		local ok, err = pcall(function()
			path:ComputeAsync(hrp.Position, tRoot.Position)
		end)

		if ok and path.Status == Enum.PathStatus.Success then
			local waypoints = path:GetWaypoints()
			for i, wp in ipairs(waypoints) do
				if not State.AutoOn or State.Mode ~= "chasing" then break end
				if wp.Action == Enum.PathWaypointAction.Jump then
					hum.Jump = true
				end
				hum:MoveTo(wp.Position)
				-- Fakeout every ~5 waypoints
				if i % 5 == 0 then
					fakeMoveRight(hrp, hum, 0.18)
				end
				local moved = hum.MoveToFinished:Wait()
				if not moved then break end
			end

			-- Check if close enough to pass bomb
			local dist = (hrp.Position - tRoot.Position).Magnitude
			if dist < 5 then
				-- Simulate bomb pass: switch to flee
				State.Mode = "fleeing"
				task.spawn(function()
					doJuke(tChar)
				end)
			end
		else
			-- Fallback: walk straight
			hum:MoveTo(tRoot.Position)
			task.wait(0.3)
		end

		task.wait(0.1)
	end
end

local function runAutoFlee()
	while State.AutoOn and State.Mode == "fleeing" do
		local target = State.Target
		local hrp = getHRP()
		local hum = getHumanoid()
		if not hrp or not hum or not target or not target.Character then task.wait(0.3) continue end
		local tRoot = target.Character:FindFirstChild("HumanoidRootPart")
		if not tRoot then task.wait(0.3) continue end

		-- Move opposite direction with fakeout
		local awayDir = (hrp.Position - tRoot.Position).Unit
		local fakeAngle = math.rad(math.random(-40, 40))
		local fakeDir = Vector3.new(
			awayDir.X * math.cos(fakeAngle) - awayDir.Z * math.sin(fakeAngle),
			0,
			awayDir.X * math.sin(fakeAngle) + awayDir.Z * math.cos(fakeAngle)
		)
		hum:MoveTo(hrp.Position + fakeDir * 20)
		hum.MoveToFinished:Wait()
		task.wait(0.15)
	end
end

local function startAutoLoop()
	if autoThread then task.cancel(autoThread) end
	State.Mode = "chasing"
	autoThread = task.spawn(function()
		while State.AutoOn do
			if State.Mode == "chasing" then
				runAutoChase()
			elseif State.Mode == "fleeing" then
				runAutoFlee()
			end
			task.wait(0.05)
		end
	end)
end

local function stopAuto()
	State.Mode = "idle"
	State.Target = nil
	if autoThread then task.cancel(autoThread) autoThread = nil end
	local hum = getHumanoid()
	local hrp = getHRP()
	if hum and hrp then hum:MoveTo(hrp.Position) end
	GUI.UsernameLabel.Text = "(username)"
end

-- ══════════════════════════════════════════
--              FACING (Camera Lock-On)
-- ══════════════════════════════════════════
local facingConn

local function setupFacing()
	if facingConn then facingConn:Disconnect() facingConn = nil end
	if not State.FacingOn or not State.AutoOn then return end

	facingConn = RunService.RenderStepped:Connect(function()
		if not State.FacingOn or not State.AutoOn then return end
		local target = State.Target
		if not target or not target.Character then return end
		local tRoot = target.Character:FindFirstChild("HumanoidRootPart")
		local hrp   = getHRP()
		if not tRoot or not hrp then return end

		-- Face character toward target
		local dir = (tRoot.Position - hrp.Position)
		dir = Vector3.new(dir.X, 0, dir.Z)
		if dir.Magnitude > 0.1 then
			hrp.CFrame = CFrame.new(hrp.Position, hrp.Position + dir)
		end

		-- Lock camera
		Camera.CFrame = CFrame.new(Camera.CFrame.Position, tRoot.Position)
	end)
end

