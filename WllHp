		local d = i.Position - dragStart
		mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset+d.X, startPos.Y.Scale, startPos.Y.Offset+d.Y)
	end
end)

-- ===== THEME =====
local function applyTheme()
	local col = C()
	mainStroke.Color = col.stroke
	proxLabel.TextColor3 = col.proxTxt
	infoLabel.TextColor3 = col.infoTxt
	sliderTrack.BackgroundColor3 = col.trackBg
	sliderFill.BackgroundColor3 = col.trackFill
	sliderKnob.BackgroundColor3 = col.knobBg
	sliderKnob.TextColor3 = col.trackFill
	kStroke.Color = col.knobStroke
	kShd.BackgroundColor3 = col.btnShd
	resetBtn.BackgroundColor3 = col.btnA
	rShd.BackgroundColor3 = col.btnShd
	rGrad.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, col.btnA), ColorSequenceKeypoint.new(1, col.btnB)})
	titleGrad.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, col.titleA), ColorSequenceKeypoint.new(1, col.titleB)})
	titleFix.BackgroundColor3 = col.titleB
	titleBar.BackgroundColor3 = col.titleA

	if isDarkMode then
		bgGrad.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.fromRGB(16, 22, 48)), ColorSequenceKeypoint.new(1, Color3.fromRGB(10, 14, 32))})
		mainFrame.BackgroundColor3 = DM.bg
		moonCut.BackgroundColor3 = col.titleB
		sunHolder.Visible = false
		moonHolder.Visible = true
		shadow.BackgroundColor3 = DM.shadow
	else
		bgGrad.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.fromRGB(240, 246, 255)), ColorSequenceKeypoint.new(1, Color3.fromRGB(220, 232, 255))})
		mainFrame.BackgroundColor3 = LM.bg
		sunHolder.Visible = true
		moonHolder.Visible = false
		shadow.BackgroundColor3 = LM.shadow
	end

	-- update button not-enabled state colors
	if not wallhopEnabled then
		whGrad.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, col.btnA), ColorSequenceKeypoint.new(1, col.btnB)})
		whShd.BackgroundColor3 = col.btnShd
	end
	if not infiniteJumpEnabled then
		ijGrad.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, col.btnA), ColorSequenceKeypoint.new(1, col.btnB)})
		ijShd.BackgroundColor3 = col.btnShd
	end
end

