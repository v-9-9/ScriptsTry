-- ══════════════════════════════════════════
--              HELPERS
-- ══════════════════════════════════════════
local function getCharacter()
	return LocalPlayer.Character
end

local function getHRP()
	local c = getCharacter()
	return c and c:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
	local c = getCharacter()
	return c and c:FindFirstChildOfClass("Humanoid")
end

local function isNearWall()
	local hrp = getHRP()
	if not hrp then return false, nil end
	local dirs = {
		Vector3.new(1,0,0), Vector3.new(-1,0,0),
		Vector3.new(0,0,1), Vector3.new(0,0,-1),
	}
	local params = RaycastParams.new()
	params.FilterDescendantsInstances = {getCharacter()}
	params.FilterType = Enum.RaycastFilterType.Exclude
	for _, dir in ipairs(dirs) do
		local result = workspace:Raycast(hrp.Position, dir * 1.5, params)
		if result then
			return true, result.Normal
		end
	end
	return false, nil
end

local function hasBombTool()
	local c = getCharacter()
	if not c then return false end
	for _, v in ipairs(c:GetChildren()) do
		if v:IsA("Tool") and v.Name:lower():find("bomb") then
			return true
		end
	end
	local bp = LocalPlayer.Backpack
	if bp then
		for _, v in ipairs(bp:GetChildren()) do
			if v:IsA("Tool") and v.Name:lower():find("bomb") then
				return true
			end
		end
	end
	return false
end

local function isGreenTagged(character)
	if not character then return false end
	for _, v in ipairs(character:GetDescendants()) do
		if v:IsA("BillboardGui") or v:IsA("SelectionBox") then
			if v:FindFirstChildWhichIsA("Frame") or v:FindFirstChildWhichIsA("SelectionBox") then
				-- heuristic: look for green highlight
			end
		end
		if (v:IsA("SelectionBox") or v:IsA("Highlight")) then
			local col = v:IsA("SelectionBox") and v.Color3 or v.FillColor
			if col and col.G > 0.5 and col.R < 0.4 and col.B < 0.4 then
				return true
			end
		end
	end
	return false
end

local function findNearestTarget()
	local hrp = getHRP()
	if not hrp then return nil end
	local best, bestDist = nil, math.huge
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer then
			local c = p.Character
			if c and not isGreenTagged(c) then
				local root = c:FindFirstChild("HumanoidRootPart")
				local hum  = c:FindFirstChildOfClass("Humanoid")
				if root and hum and hum.Health > 0 then
					local d = (root.Position - hrp.Position).Magnitude
					if d < bestDist then
						bestDist = d
						best = p
					end
				end
			end
		end
	end
	return best
end

