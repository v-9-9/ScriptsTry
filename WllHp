	local lName=Instance.new("TextLabel",btn)
	lName.Size=UDim2.new(1,-28,0.52,0); lName.Position=UDim2.new(0,27,0,0)
	lName.BackgroundTransparency=1; lName.Text=label
	lName.TextColor3=Color3.fromRGB(255,255,255); lName.TextSize=14
	lName.Font=Enum.Font.GothamBold; lName.TextXAlignment=Enum.TextXAlignment.Left; lName.ZIndex=4

	local lStat=Instance.new("TextLabel",btn)
