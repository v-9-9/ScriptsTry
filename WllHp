	local grad=Instance.new("UIGradient",btn)
	grad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,LM().btn1),ColorSequenceKeypoint.new(1,LM().btn2)}); grad.Rotation=90

	-- indicator dot
	local dot=Instance.new("Frame",btn)
