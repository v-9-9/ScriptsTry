-- helper: make a 3D button
local function make3DBtn(parent, posY, height, textA, textB, colorA, colorB, shdColor)
	local btn = Instance.new("TextButton", parent)
	btn.Size = UDim2.new(1, 0, 0, height)
	btn.Position = UDim2.new(0, 0, 0, posY)
	btn.BackgroundColor3 = colorA
	btn.BorderSizePixel = 0
	btn.Text = ""
	btn.ZIndex = 3
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 12)

	local shd = Instance.new("Frame", btn)
	shd.Size = UDim2.new(1, 0, 1, 5)
	shd.Position = UDim2.new(0, 0, 0, 4)
	shd.BackgroundColor3 = shdColor
	shd.BorderSizePixel = 0
	shd.ZIndex = btn.ZIndex - 1
	Instance.new("UICorner", shd).CornerRadius = UDim.new(0, 12)

	local grad = Instance.new("UIGradient", btn)
	grad.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, colorA), ColorSequenceKeypoint.new(1, colorB)})
	grad.Rotation = 90

	local dot = Instance.new("Frame", btn)
	dot.Size = UDim2.new(0, 9, 0, 9)
	dot.Position = UDim2.new(0, 11, 0.5, -4)
	dot.BackgroundColor3 = Color3.fromRGB(145, 155, 192)
	dot.BorderSizePixel = 0
	Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

	local la = Instance.new("TextLabel", btn)
	la.Size = UDim2.new(1, -28, 0.52, 0)
	la.Position = UDim2.new(0, 26, 0, 0)
	la.BackgroundTransparency = 1
	la.Text = textA
	la.TextColor3 = Color3.fromRGB(255, 255, 255)
	la.TextSize = 14
	la.Font = Enum.Font.GothamBold
	la.TextXAlignment = Enum.TextXAlignment.Left

	local lb = Instance.new("TextLabel", btn)
	lb.Size = UDim2.new(1, -28, 0.48, 0)
	lb.Position = UDim2.new(0, 26, 0.52, 0)
	lb.BackgroundTransparency = 1
	lb.Text = textB
	lb.TextColor3 = Color3.fromRGB(175, 195, 255)
	lb.TextSize = 12
	lb.Font = Enum.Font.Gotham
	lb.TextXAlignment = Enum.TextXAlignment.Left

	return btn, shd, grad, dot, la, lb
end

