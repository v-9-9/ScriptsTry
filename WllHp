	shd2.BackgroundColor3=LM().btnShd; shd2.BorderSizePixel=0; shd2.ZIndex=2
	Instance.new("UICorner",shd2).CornerRadius=UDim.new(0,13)

	local btn=Instance.new("TextButton",wrap)
	btn.Size=UDim2.new(1,0,1,0); btn.Position=UDim2.new(0,0,0,0)
	btn.BackgroundColor3=LM().btn1; btn.BorderSizePixel=0; btn.Text=""; btn.ZIndex=3
