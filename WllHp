local function setButtonState(enabled, grad, shd, statusL, dotFrame)
	local col = C()
	if enabled then
		grad.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.fromRGB(48, 188, 105)), ColorSequenceKeypoint.new(1, Color3.fromRGB(25, 135, 68))})
		shd.BackgroundColor3 = Color3.fromRGB(14, 88, 45)
		statusL.TextColor3 = Color3.fromRGB(172, 255, 195)
		statusL.Text = getText("enabled")
		dotFrame.BackgroundColor3 = Color3.fromRGB(68, 255, 128)
	else
		grad.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, col.btnA), ColorSequenceKeypoint.new(1, col.btnB)})
		shd.BackgroundColor3 = col.btnShd
